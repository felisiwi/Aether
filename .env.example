# Repo root — Vite reads env from here (see client/vite.config.ts envDir).
# Local: copy to `.env`. Vercel: set the same keys in Project → Settings → Environment Variables.

# WebSocket URL of the signalling server (wss:// in production). Login POST /api/login uses the
# same host with https:// instead of wss:// (or http:// for ws:// localhost).
VITE_SIGNAL_URL=ws://localhost:3000

# Optional: WebRTC TURN (recommended for strict NAT / mobile). Leave unset to use STUN only.
# VITE_TURN_URL=
# VITE_TURN_USERNAME=
# VITE_TURN_CREDENTIAL=
